# ===========================================================================
# Mini-OpenClaw 后端环境配置模板
# 复制本文件为 .env 并填入真实值。.env 不会被提交到版本库。
# ===========================================================================

# --- 模型接口（兼容 OpenAI API 格式）---
# 支持 DeepSeek / OpenRouter / Claude(经兼容层) 等任意 OpenAI 兼容端点。
#
# DeepSeek 示例：
#   LLM_API_KEY=sk-xxxxxxxx
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_MODEL=deepseek-chat
#
# OpenRouter 示例：
#   LLM_API_KEY=sk-or-xxxxxxxx
#   LLM_BASE_URL=https://openrouter.ai/api/v1
#   LLM_MODEL=anthropic/claude-3.5-sonnet

LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7

# --- Embedding（RAG 用，OpenAI 兼容）---
# 留空则复用 LLM_API_KEY / LLM_BASE_URL。
# 注意：DeepSeek 当前不提供 embedding 接口，做 RAG 时需指向支持 embedding 的端点。
EMBED_API_KEY=
EMBED_BASE_URL=
EMBED_MODEL=text-embedding-3-small

# --- 服务 ---
SERVER_PORT=8002
